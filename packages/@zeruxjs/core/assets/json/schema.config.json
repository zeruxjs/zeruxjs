{
    "title": "JSON schema for ZeruxJS Framework",
    "$schema": "https://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "$schema": {
            "type": "string"
        },
        "type": {
            "description": "How Framework will load Files",
            "type": "string",
            "default": "fix",
            "enum": [
                "fix",
                "user-define",
                "function"
            ]
        }
    },
    "required": [
        "apiVersion",
        "name",
        "title"
    ],
    "additionalProperties": false
}